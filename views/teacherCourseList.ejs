<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>เลือกรายวิชาเพื่อกรอกคะแนน</title>
    <link href="/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <style>
        body { margin: 0; background-color: #dbe0e5; font-family: 'Prompt', sans-serif; height: 100vh; overflow: hidden; display: flex; justify-content: center; }
        .app-container { width: 1280px; max-width: 100%; height: 100vh; background-color: #f4f5f8; display: flex; flex-direction: column; box-shadow: 0 0 25px rgba(0,0,0,0.1); }
        .top-wrapper { height: 64px; flex-shrink: 0; background-color: #ffffff; z-index: 10; }
        .bottom-wrapper { display: flex; flex: 1; overflow: hidden; }
        .sidebar-wrapper { width: 280px; flex-shrink: 0; background-color: #F4F7FE; border-right: 1px solid #E0E0E0; }
        .main-content { flex: 1; padding: 40px; overflow-y: auto; }


        .course-card {
            display: flex;
            flex-direction: column;
            background: #ffffff;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 4px 10px rgba(0,0,0,0.05);
            transition: transform 0.2s, box-shadow 0.2s;
            text-decoration: none;
            color: #333333;
            border: 1px solid #e0e0e0;
            height: 100%;
        }

        .course-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 20px rgba(0,0,0,0.1);
            color: #333333;
        }

        .card-top-color {
            height: 120px;
            width: 100%;
        }

        .card-body-content {
            padding: 20px;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .course-title { font-size: 1.25rem; font-weight: 700; color: #1a1a1a; margin: 0; }
        .course-code { font-size: 1.05rem; font-weight: 400; color: #444; margin: 0; }
        .course-room { font-size: 1.05rem; font-weight: 400; color: #444; margin: 0; }
    </style>
</head>
<body>
    
    <div class="app-container">
        <div class="top-wrapper">
            <%- include('partials/mtbar') %>
        </div>

        <div class="bottom-wrapper">
            <div class="sidebar-wrapper">
                <%- include('partials/mlbar') %>
            </div>

            <main class="main-content">
                
                <h3 class="fw-bold mb-4" style="color: #1a1a1a;">เลือกรายวิชาเพื่อจัดการคะแนน</h3>
                
                <div class="row g-4">
                    <% 
                        const pastelColors = ['#c89bf7', '#ffbdf0', '#88f9f0', '#ffdfba', '#baffc9', '#bae1ff'];
                    %>

                    <% if (courses && courses.length > 0) { %>
                        <% courses.forEach((course) => { 
                            let colorIndex = course.course_code.split('').reduce((acc, char) => acc + char.charCodeAt(0), 0) % pastelColors.length;
                            let bgColor = pastelColors[colorIndex];
                        %>
                            <div class="col-12 col-md-6 col-lg-4">
                                <a href="/teacher/grading/<%= course.section_id %>" class="course-card">
                                    <div class="card-top-color" style="background-color: <%= bgColor %>;"></div>
                                    <div class="card-body-content">
                                        <div class="course-title"><%= course.course_name %></div>
                                        <div class="course-code"><%= course.course_code %></div>
                                        <div class="course-room"><%= course.room %></div>
                                    </div>
                                </a>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <div class="col-12">
                            <div class="alert alert-warning text-center py-4 rounded-3 border-dashed">
                                คุณยังไม่มีตารางสอนในภาคเรียนนี้
                            </div>
                        </div>
                    <% } %>
                </div>

            </main>
        </div>
    </div>

</body>
</html>