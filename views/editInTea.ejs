<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>แก้ไขข้อมูลอาจารย์ | ระบบจัดการการศึกษา</title>
    <link href="/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <style>
        body { margin: 0; background-color: #dbe0e5; font-family: 'Prompt', sans-serif; height: 100vh; overflow: hidden; display: flex; justify-content: center; }
        .app-container { width: 1280px; max-width: 100%; height: 100vh; background-color: #f4f5f8; display: flex; flex-direction: column; box-shadow: 0 0 25px rgba(0,0,0,0.1); }
        .top-wrapper { height: 64px; flex-shrink: 0; background-color: #ffffff; z-index: 10; border-bottom: 1px solid #E0E0E0;}
        .bottom-wrapper { display: flex; flex: 1; overflow: hidden; }
        .sidebar-wrapper { width: 280px; flex-shrink: 0; background-color: #F4F7FE; border-right: 1px solid #E0E0E0; }
        .main-content { flex: 1; padding: 25px; overflow-y: auto; }
        
        /* สไตล์สำหรับกล่องฟอร์มแก้ไข (โทนสีเขียว) */
        .admin-card { background-color: #fff; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); overflow: hidden; border: 1px solid #e0e0e0; margin: 0 auto; max-width: 1000px; }
        .admin-header { background-color: #D1E7DD; color: #0F5132; padding: 18px 25px; border-bottom: 1px solid #e0e0e0; }
        
        /* สไตล์เฉพาะสำหรับฟอร์มกรอกข้อมูล */
        .form-label { font-weight: 500; color: #495057; margin-bottom: 0.5rem; font-size: 0.95rem; }
        .form-control, .form-select { border-radius: 8px; padding: 0.6rem 1rem; border: 1px solid #ced4da; }
        .form-control:focus, .form-select:focus { border-color: #75b798; box-shadow: 0 0 0 0.25rem rgba(25, 135, 84, 0.15); }
        .form-control[readonly] { background-color: #f8f9fa; cursor: not-allowed; color: #6c757d; }
        .required-asterisk { color: #dc3545; font-weight: bold; }
    </style>
</head>
<body>
    <div class="app-container">

        <div class="top-wrapper">
            <%- include('partials/mtbar') %>
        </div>

        <div class="bottom-wrapper">

            <div class="sidebar-wrapper">
                <%- include('partials/mlbar') %>
            </div>

            <main class="main-content">
                
                <div class="admin-card">
                    
                    <div class="admin-header d-flex justify-content-between align-items-center">
                        <h5 class="fw-bold mb-0">
                            <i class="bi bi-pencil-square me-2"></i>แก้ไขข้อมูลอาจารย์
                        </h5>
                        <a href="/admin/man/teacher" class="btn btn-sm btn-outline-success bg-white rounded-pill px-3 shadow-sm" style="color: #0F5132; border-color: #0F5132;">
                            <i class="bi bi-arrow-left"></i> กลับหน้าจัดการ
                        </a>
                    </div>

                    <div class="row g-0">
                        
                        <div class="col-md-4 p-4 d-flex flex-column align-items-center justify-content-center bg-light border-end">
                            <div class="shadow-sm rounded-circle p-1 bg-white mb-3" style="width: 160px; height: 160px;">
                                <img src="<%= data.profile_image ? '/img/' + data.profile_image : 'https://ui-avatars.com/api/?name=' + data.first_name + '&background=D1E7DD&color=0F5132' %>" 
                                     alt="Profile" 
                                     class="rounded-circle w-100 h-100" 
                                     style="object-fit: cover;">
                            </div>
                            <h4 class="fw-bold text-center text-dark mb-1">
                                <%= data.first_name %> <%= data.last_name %>
                            </h4>
                            <span class="badge bg-success rounded-pill mt-2 px-3 py-2">
                                รหัสอาจารย์: <%= data.teacher_code %>
                            </span>
                        </div>

                        <div class="col-md-8 p-4 p-md-5">
                            
                            <form action="/admin/man/changeTea" method="POST">
                                
                                <h5 class="mb-4 fw-bold text-success border-bottom pb-2">รายละเอียดข้อมูลส่วนตัว</h5>
                                
                                <div class="row mb-3 g-3">
                                    <div class="col-md-6">
                                        <label for="first" class="form-label">ชื่อ <span class="required-asterisk">*</span></label>
                                        <input type="text" class="form-control" name="first" id="first" value="<%= data.first_name %>" required>
                                    </div>
                                    <div class="col-md-6">
                                        <label for="last" class="form-label">นามสกุล <span class="required-asterisk">*</span></label>
                                        <input type="text" class="form-control" name="last" id="last" value="<%= data.last_name %>" required>
                                    </div>
                                </div>

                                <div class="row mb-3 g-3">
                                    <div class="col-md-6">
                                        <label for="ID" class="form-label text-muted">รหัสประจำตัวอาจารย์ <small>(ห้ามแก้ไข)</small></label>
                                        <input type="text" class="form-control" name="ID" id="ID" value="<%= data.teacher_code %>" readonly>
                                    </div>
                                    <div class="col-md-6">
                                        <label for="email" class="form-label text-muted">อีเมล <small>(ห้ามแก้ไข)</small></label>
                                        <input type="email" class="form-control" name="email" id="email" value="<%= data.email %>" readonly>
                                    </div>
                                </div>
                                
                                <div class="row mb-3 g-3">
                                    <div class="col-md-6">
                                        <label for="gender" class="form-label text-muted">เพศ <small>(ห้ามแก้ไข)</small></label>
                                        <input type="text" class="form-control" name="gender" id="gender" value="<%= data.gender === 'male' ? 'ชาย' : 'หญิง' %>" readonly>
                                    </div>
                                    <div class="col-md-6">
                                        <label for="DOB" class="form-label text-muted">วัน - เดือน - ปี เกิด <small>(ห้ามแก้ไข)</small></label>
                                        <input type="date" class="form-control" name="DOB" id="DOB" value="<%= data.birth_date %>" readonly>
                                    </div>
                                </div>

                                <div class="row mb-3 g-3">
                                    <div class="col-md-6">
                                        <label for="tel" class="form-label">เบอร์โทรศัพท์</label>
                                        <input type="tel" class="form-control" name="tel" id="tel" value="<%= data.phone %>">
                                    </div>
                                    <div class="col-md-6">
                                        <label for="edLev" class="form-label">วุฒิการศึกษา</label>
                                        <input type="text" class="form-control" name="edLev" id="edLev" value="<%= data.education_level %>">
                                    </div>
                                </div>

                                <div class="row mb-4 g-3 border-bottom pb-4">
                                    <div class="col-md-12">
                                        <label for="status" class="form-label">สถานะการทำงาน <span class="required-asterisk">*</span></label>
                                        <select id="status" name="status" class="form-select">
                                            <option value="1" <%= (data.is_active == 1) ? 'selected' : '' %>>ยังคงปฏิบัติงาน (Active)</option>
                                            <option value="0" <%= (data.is_active == 0) ? 'selected' : '' %>>พ้นสภาพ / ออกจากโรงเรียนไปแล้ว (Inactive)</option>
                                        </select>
                                    </div>
                                </div>

                                <div class="d-flex justify-content-end gap-3 mt-2">
                                    <a href="/admin/man/teacher" class="btn btn-light px-4 border rounded-pill">ยกเลิก</a>
                                    <button type="submit" class="btn btn-success px-5 shadow-sm rounded-pill fw-semibold">
                                        <i class="bi bi-save me-1"></i> บันทึกการเปลี่ยนแปลง
                                    </button>
                                </div>

                            </form>
                        </div>
                    </div> </div> </main>
        </div>
    </div>
</body>
</html>