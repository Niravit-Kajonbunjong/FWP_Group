<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>userInfo</title>
    <style>
        .info {
            display: grid;
            grid-template-columns: 45% 45%;
            gap: 1%;
            margin: 5%;
        }

        table {
            width: 60%;
            text-align: left;
            margin: auto;
        }

        th,
        td {
            padding: 1%;
        }
    </style>
</head>

<body>
    <%- include("partials/mtbar") %>
    <!-- -->
    <div class="info">
        <div>
            <img src="/img/<%= data.profile_imgae %>"> <!-- maybe in would change it later-->
        </div>
        <div>
            <table>
                <tr>
                    <th>ชื่อ - นามสกุล</th>
                    <th>เพศ</th>
                </tr>
                <tr>
                    <td><%= data.first_name %>  <%= data.last_name %></td>
                    <td><%= data.gender %></td>
                </tr>
                <tr>
                    <th>วัน / เดือน / ปี เกิด</th>
                    <th>อายุ</th>
                </tr>
                <tr>
                    <td><%= data.birth_date %></td>
                    <% 
                        const birthDate = new Date(<% data.birth_date %>);
                        const today = new Date();
                        let age = today.getFullYear() - birthDate.getFullYear();
                        const monthDiff = today.getMonth() - birthDate.getMonth();
                        if (monthDiff < 0 || (monthDiff == 0 && today.getDate() < birthDate.getDate())) {
                            age--;
                        }
                    %>
                    <td><%= age %> ปี</td>
                </tr>
                <tr>
                    <th>อีเมล</th>
                </tr>
                <tr>
                    <td><%= data.email %></td>
                </tr>
                <tr>
                    <th>เบอร์โทร</th>
                </tr>
                <tr>
                    <td><%= data.phone %></td>
                </tr>
            </table>
        </div>
    </div>
</body>

</html>