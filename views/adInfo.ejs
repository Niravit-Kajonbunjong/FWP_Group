<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Information</title>
        <link href="/css/bootstrap.min.css" rel="stylesheet">
    <script src="/js/bootstrap.bundle.min.js"></script>
    <style>
.main-card {
    border-radius: 24px;
    overflow: hidden;
    border: none;
    max-width: 900px;
    width: 95%;
}

.profile-img-container {
    width: 180px;
    height: 180px;
    border-radius: 20px;
    overflow: hidden;
    background: #fff;
    border: 4px solid #fff;
}

.profile-img-container img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.info-label {
    display: block;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    font-weight: 700;
    color: #adb5bd;
    margin-bottom: 4px;
}

.info-value {
    font-size: 1.1rem;
    font-weight: 600;
    color: #333;
    margin-bottom: 0;
}
    </style>
</head>

<body>
    <%- include("partials/mtbar") %>
    <div class="container d-flex justify-content-center align-items-center min-vh-100 py-5">
    <div class="main-card shadow-lg bg-white">
        <div class="row g-0">
            <div class="col-md-4 d-flex flex-column align-items-center justify-content-center border-end bg-light p-4 rounded-start">
                <div class="profile-img-container shadow">
                    <img src="/img/<%= data.profile_image %>" alt="Profile Image" class="img-fluid">
                </div>
                <h4 class="mt-3 fw-bold text-center"><%= data.first_name %> <%= data.last_name %></h4>
                <p class="text-muted small">ข้อมูลสมาชิก</p>
            </div>

            <div class="col-md-8 p-5">
                <h3 class="mb-4 fw-bold text-primary border-bottom pb-2">รายละเอียดข้อมูล</h3>
                
                <div class="row mb-4">
                    <div class="col-6">
                        <label class="info-label">ชื่อ - นามสกุล</label>
                        <p class="info-value"><%= data.first_name %> <%= data.last_name %></p>
                    </div>
                    <div class="col-6">
                        <label class="info-label">เพศ</label>
                        <p class="info-value"><%= data.gender %></p>
                    </div>
                </div>

                <div class="row mb-4">
                    <div class="col-6">
                        <label class="info-label">วัน - เดือน - ปี เกิด</label>
                        <p class="info-value"><%= data.birth_date %></p>
                    </div>
                    <div class="col-6">
                        <label class="info-label">อายุ</label>
                        <% 
                            const birthDate = new Date(data.birth_date); 
                            const today = new Date(); 
                            let age = today.getFullYear() - birthDate.getFullYear(); 
                            const monthDiff = today.getMonth() - birthDate.getMonth(); 
                            if (monthDiff < 0 || (monthDiff == 0 && today.getDate() < birthDate.getDate())) { 
                                age--; 
                            } 
                        %>
                        <p class="info-value"><%= age %> ปี</p>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="info-label">อีเมล</label>
                    <p class="info-value text-lowercase"><%= data.email %></p>
                </div>

                <div class="mb-4">
                    <label class="info-label">เบอร์โทรศัพท์</label>
                    <p class="info-value"><%= data.phone || '-' %></p>
                </div>

            </div>
        </div>
    </div>
</div>
</body>

</html>