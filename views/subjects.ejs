<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>จัดการวิชาและหลักสูตร</title>
    <link href="/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    
    <style>
        /* โครงสร้างหลัก */
        body { margin: 0; background-color: #dbe0e5; font-family: 'Prompt', sans-serif; height: 100vh; overflow: hidden; display: flex; justify-content: center; }
        .app-container { width: 1280px; max-width: 100%; height: 100vh; background-color: #f4f5f8; display: flex; flex-direction: column; box-shadow: 0 0 25px rgba(0,0,0,0.1); }
        .top-wrapper { height: 64px; flex-shrink: 0; background-color: #ffffff; z-index: 10; }
        .bottom-wrapper { display: flex; flex: 1; overflow: hidden; }
        .sidebar-wrapper { width: 280px; flex-shrink: 0; background-color: #F4F7FE; border-right: 1px solid #E0E0E0; }
        .main-content { flex: 1; padding: 40px; overflow-y: auto; }

        /* สไตล์การ์ดวิชา */
        :root { --purple: #c5b4ff; --pink: #ffd1e3; --cyan: #b2ffff; --primary-btn: #4A3AFF; }
        .subject-card { border: none; border-radius: 20px; overflow: hidden; transition: 0.3s; background: white; box-shadow: 0 10px 30px rgba(0,0,0,0.05); border: 1px solid #eee; }
        .subject-card:hover { transform: translateY(-8px); box-shadow: 0 15px 35px rgba(0,0,0,0.1); }
        .card-banner { height: 100px; }
        .banner-0 { background-color: var(--purple); }
        .banner-1 { background-color: var(--pink); }
        .banner-2 { background-color: var(--cyan); }
        
        .search-container { background: white; border-radius: 50px; padding: 5px 20px; border: 1px solid #eee; }
        .btn-add-subject { background: var(--primary-btn); color: white; border-radius: 15px; width: 45px; height: 45px; border: none; font-size: 24px; transition: 0.3s; display: flex; align-items: center; justify-content: center; }
        .btn-add-subject:hover { background: #3629cc; transform: scale(1.1); }
        .action-btn { border-radius: 10px; width: 35px; height: 35px; display: flex; align-items: center; justify-content: center; transition: 0.2s; }
        .action-btn:hover { transform: scale(1.1); }
        
        .card-inner-box { background: white; border-radius: 15px; padding: 15px; margin-top: -40px; border: 1px solid rgba(0,0,0,0.03); }
    </style>
</head>
<body>
    
    <div class="app-container">
        <div class="top-wrapper">
            <%- include('partials/mtbar') %>
        </div>

        <div class="bottom-wrapper">
            <div class="sidebar-wrapper">
                <%- include('partials/mlbar') %>
            </div>

            <main class="main-content">
                <div class="d-flex justify-content-between align-items-center mb-5">
                    <h3 class="fw-bold m-0" style="color: #1a1a1a;">จัดการวิชาและหลักสูตร</h3>
                    
                    <div class="d-flex align-items-center gap-3">
                        <form action="/regis/curriculum" method="GET" class="search-container d-flex align-items-center shadow-sm">
                            <input type="text" name="search" class="form-control border-0 bg-transparent" 
                                   placeholder="ค้นหาวิชา..." value="<%= searchQuery %>" style="width: 200px; outline: none; box-shadow: none;">
                            <button type="submit" class="btn text-muted p-0"><i class="fa-solid fa-magnifying-glass"></i></button>
                        </form>
                        <button class="btn-add-subject shadow-sm" data-bs-toggle="modal" data-bs-target="#addSubjectModal">
                            <i class="fa-solid fa-plus"></i>
                        </button>
                    </div>
                </div>

                <div class="row g-4">
                    <% if (subjects && subjects.length > 0) { %>
                        <% subjects.forEach((subject, index) => { %>
                            <div class="col-xl-4 col-md-6">
                                <div class="card subject-card h-100">
                                    <div class="card-banner banner-<%= index % 3 %>"></div>
                                    <div class="card-body p-4 pt-0">
                                        <div class="card-inner-box shadow-sm mb-3">
                                            <div class="d-flex justify-content-between align-items-start">
                                                <h5 class="fw-bold m-0 text-dark"><%= subject.subject_name %></h5>
                                                <span class="badge bg-light text-primary rounded-pill border"><%= subject.credits %> นก.</span>
                                            </div>
                                            <div class="text-muted small mt-2">รหัสวิชา: <%= subject.course_code || subject.subject_id %></div>
                                            <div class="text-primary small fw-bold mt-1">
                                                <i class="fa-solid fa-location-dot me-1"></i><%= subject.room || 'ยังไม่ระบุห้อง' %>
                                            </div>
                                        </div>
                                        
                                        <div class="d-flex justify-content-end gap-2">
                                            <a href="/regis/edit/<%= subject.subject_id %>" class="btn btn-light action-btn text-primary border shadow-sm" title="แก้ไข">
                                                <i class="fa-solid fa-pen"></i>
                                            </a>
                                            <form action="/regis/delete/<%= subject.subject_id %>" method="POST" onsubmit="return confirm('ยืนยันการลบทิ้งข้อมูลวิชานี้?')">
                                                <button type="submit" class="btn btn-light action-btn text-danger border shadow-sm" title="ลบ">
                                                    <i class="fa-solid fa-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <div class="col-12 text-center py-5">
                            <div class="opacity-25 mb-3">
                                <i class="fa-solid fa-book-open fa-4x text-muted"></i>
                            </div>
                            <p class="text-muted">ไม่พบข้อมูลรายวิชาในฐานข้อมูล</p>
                        </div>
                    <% } %>
                </div>
            </main>
        </div>
    </div>

    <div class="modal fade" id="addSubjectModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0" style="border-radius: 25px;">
                <div class="modal-header border-0 pt-4 px-4">
                    <h5 class="fw-bold">เพิ่มรายวิชาใหม่ (Course)</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form action="/regis/add-subject" method="POST">
                    <div class="modal-body p-4">
                        <div class="mb-3">
                            <label class="small text-muted mb-1">รหัสวิชา</label>
                            <input type="text" name="course_code" class="form-control rounded-3" placeholder="เช่น CS101" required>
                        </div>
                        <div class="mb-3">
                            <label class="small text-muted mb-1">ชื่อวิชา</label>
                            <input type="text" name="subject_name" class="form-control rounded-3" placeholder="เช่น Advanced Mathematics" required>
                        </div>
                        <div class="row">
                            <div class="col-6 mb-3">
                                <label class="small text-muted mb-1">หน่วยกิต</label>
                                <input type="number" name="credits" class="form-control rounded-3" value="3" required>
                            </div>
                            <div class="col-6 mb-3">
                                <label class="small text-muted mb-1">ห้องเรียน</label>
                                <input type="text" name="room" class="form-control rounded-3" placeholder="เช่น Room 402">
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer border-0 pb-4 px-4">
                        <button type="submit" class="btn btn-primary w-100 py-2 rounded-3 shadow-sm">บันทึกข้อมูลเข้าระบบ</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>