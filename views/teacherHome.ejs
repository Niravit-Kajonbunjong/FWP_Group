<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Teacher Profile</title>
    <link href="/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/index.css">
    
    <style>
        body {
            margin: 0;
            font-family: 'Prompt', sans-serif;
            background-color: #f4f5f8;
            height: 100vh;
            overflow: hidden; 
        }

        /* โครงสร้าง Layout หลัก */
        .app-container {
            display: flex;
            flex-direction: column;
            height: 100vh; 
        }

        .bottom-wrapper {
            display: flex;
            flex: 1;
            overflow: hidden; 
        }

        .sidebar-wrapper {
            width: 280px;
            flex-shrink: 0;
            background-color: #F4F7FE;
            border-right: 1px solid #E0E0E0;
            overflow-y: auto; 
        }

        .main-content {
            flex-grow: 1;
            display: flex;
            justify-content: center;
            align-items: flex-start;
            padding: 2%;
            overflow-y: auto; 
        }

        /* ตกแต่งกล่องโปรไฟล์หลัก */
        .content-container {
            width: 100%;
            max-width: 950px;
            background-color: #ffffff;
            border-radius: 16px;
            padding: 45px 50px;
            border: 1px solid #eaeef4;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03); /* เงาอ่อนๆ ให้กล่องลอยขึ้น */
        }

        /* ตกแต่งรูปโปรไฟล์และสถานะ */
        .profile-img-box { 
            position: relative; 
            display: inline-block; 
        }
        
        .profile-img { 
            width: 260px; 
            height: 260px; 
            object-fit: cover; 
            border-radius: 20px; 
            border: 5px solid #f8faff; 
            box-shadow: 0 8px 16px rgba(0,0,0,0.08); /* เงาใต้รูป */
        }

        .status-badge {
            position: absolute; 
            bottom: -10px; 
            right: -10px;
            background-color: #00b16a; 
            color: white;
            width: 55px; 
            height: 55px; 
            border-radius: 50%;
            display: flex; 
            justify-content: center; 
            align-items: center;
            font-size: 1.6rem; 
            font-weight: bold; 
            border: 4px solid #fff;
            box-shadow: 0 4px 8px rgba(0,177,106,0.3);
        }

        /* ตกแต่งข้อความข้อมูล (ให้ดูเหมือนฟอร์มที่สะอาดตา) */
        .info-label { 
            font-weight: 600; 
            color: #8c98a4; /* สีเทาอ่อนให้อ่านสบายตา */
            margin-bottom: 4px; 
            font-size: 0.9rem; 
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .info-value { 
            font-weight: 500;
            color: #1e2022; 
            margin-bottom: 24px; 
            font-size: 1.05rem; 
            padding-bottom: 8px;
            border-bottom: 1px solid #f0f2f5; /* เส้นใต้บางๆ แยกข้อมูลแต่ละส่วน */
        }
    </style>
</head>
<body>

        <div class="app-container">
        
        <%- include('partials/mtbar') %>

        <div class="bottom-wrapper">
            
            <div class="sidebar-wrapper">
                <%- include('partials/mlbar') %>
            </div>

            <div class="main-content">
                <div class="content-container shadow-sm">
                    <div class="row align-items-center">
                        <div class="col-md-5 text-center mb-4 mb-md-0">
                            <div class="profile-img-box">
                                <img src="<%= user.profile_image || user.avatar || '/images/default-avatar.png' %>" alt="Profile" class="profile-img shadow-sm">
                            </div>
                        </div>

                        <div class="col-md-7 ps-md-5">
                            <div class="row">
                                <div class="col-7">
                                    <div class="info-label">ชื่อ - นามสกุล</div>
                                    <div class="info-value"><%= user.first_name %> <%= user.last_name %></div>
                                </div>
                                <div class="col-5">
                                    <div class="info-label">เพศ</div>
                                    <div class="info-value"><%= user.gender %></div>
                                </div>
                                <div class="col-7">
                                    <div class="info-label">รหัสอาจารย์</div>
                                    <div class="info-value"><%= user.user_id %></div>
                                </div>
                                <div class="col-5">
                                    <div class="info-label">ห้องพัก</div>
                                    <div class="info-value">502</div>
                                </div>
                                <div class="col-7">
                                    <div class="info-label">วัน / เดือน / ปี เกิด</div>
                                    <div class="info-value">14 กุมภาพันธ์ 2005</div>
                                </div>
                                <div class="col-5">
                                    <div class="info-label">อายุ</div>
                                    <div class="info-value">21</div>
                                </div>
                                <div class="col-12">
                                    <div class="info-label">อีเมล</div>
                                    <div class="info-value"><%= user.email %></div>
                                </div>
                                <div class="col-12">
                                    <div class="info-label">เบอร์โทร</div>
                                    <div class="info-value">0123456789</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

                    </div>
    </div>

        </div> </div> </body>
</html>