<style>
    .custom-menubar {
        width: 1280px;
        max-width: 100%;
        height: 64px;
        background-color: #E3F2FD;
        margin: 0 auto;
    }
    
    .profile-link:hover {
        background-color: #c9e8fe;
        border-radius: 8px;
        transition: 0.2s;
    }
</style>

<nav class="custom-menubar d-flex justify-content-between align-items-center px-2 shadow-sm">
    
    <a href="/student/home" class="profile-link text-decoration-none text-dark d-flex align-items-center gap-3 p-1">
        <img src="<%= user.avatar %>" alt="Profile" class="rounded-circle border border-2 border-primary" style="width: 45px; height: 45px; object-fit: cover;">
        
        <div class="d-flex flex-column justify-content-center" style="line-height: 1.2;">
            <span class="fw-bold text-dark" style="font-size: 0.8rem;">
                <%= user.first_name %> <%= user.last_name %>
            </span>
            <span class="text-secondary" style="font-size: 0.7rem;">
                <%= user.role %>
            </span>
        </div>
    </a>

    <form action="/logout" method="POST">
        <button class="text-dark text-decoration-none d-flex align-items-center gap-2 px-3 py-2 rounded" 
            style="transition: 0.2s; border: none; outline: none; background: none;" 
            onmouseover="this.style.backgroundColor='#ffffff'; this.style.color='#dc3545'" 
            onmouseout="this.style.backgroundColor='transparent'; this.style.color='#212529'">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                <polyline points="16 17 21 12 16 7"></polyline>
                <line x1="21" y1="12" x2="9" y2="12"></line>
            </svg>
        </button>
    </form>
    
</nav>