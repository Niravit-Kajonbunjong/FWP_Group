<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>จัดการข้อมูลอาจารย์ | ระบบจัดการการศึกษา</title>
    <link href="/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body { margin: 0; background-color: #dbe0e5; font-family: 'Prompt', sans-serif; height: 100vh; overflow: hidden; display: flex; justify-content: center; }
        .app-container { width: 1280px; max-width: 100%; height: 100vh; background-color: #f4f5f8; display: flex; flex-direction: column; box-shadow: 0 0 25px rgba(0,0,0,0.1); }
        .top-wrapper { height: 64px; flex-shrink: 0; background-color: #ffffff; z-index: 10; border-bottom: 1px solid #E0E0E0;}
        
        /* 🌟 ระบบเลื่อนหน้าจอ (Scroll) */
        .bottom-wrapper { display: flex; flex: 1; overflow: hidden; min-height: 0; }
        .sidebar-wrapper { width: 280px; flex-shrink: 0; background-color: #F4F7FE; border-right: 1px solid #E0E0E0; overflow-y: auto; }
        .main-content { flex: 1; padding: 25px; overflow-y: auto; height: 100%; }

        .admin-card { background-color: #fff; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); border: 1px solid #e0e0e0; margin-bottom: 20px; }
        .admin-header { background-color: #D1E7DD; color: #0F5132; padding: 15px 20px; border-bottom: 1px solid #e0e0e0; }
        
        .action-btn { padding: 0.25rem 0.6rem; font-size: 0.85rem; }
        .table-hover tbody tr:hover { background-color: #f8f9fa; }
    </style>
</head>
<body>
    <div class="app-container">
        
        <div class="top-wrapper">
            <%- include('partials/mtbar') %>
        </div>

        <div class="bottom-wrapper">
            
            <div class="sidebar-wrapper">
                <%- include('partials/mlbar') %>
            </div>

            <main class="main-content">
                
                <div class="admin-card">
                    
                    <div class="admin-header d-flex justify-content-between align-items-center">
                        <div>
                            <h5 class="mb-1 fw-bold"><i class="bi bi-person-badge-fill me-2"></i>จัดการข้อมูลอาจารย์</h5>
                            <div style="font-size: 0.9rem; font-weight: 500;">
                                จำนวนอาจารย์ทั้งหมดในระบบ: <span class="badge bg-success rounded-pill ms-1"><%= total %></span> ท่าน
                            </div>
                        </div>
                        <a href="/admin/man/addTea" class="btn btn-success btn-sm px-3 fw-semibold shadow-sm rounded-pill">
                            <i class="bi bi-plus-lg me-1"></i> เพิ่มอาจารย์ใหม่
                        </a>
                    </div>

                    <div class="p-0 table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th width="25%" class="ps-4">ชื่อ - นามสกุล</th>
                                    <th width="15%" class="text-center">รหัสอาจารย์</th>
                                    <th width="15%">วุฒิการศึกษา</th>
                                    <th width="15%">เบอร์โทรศัพท์</th>
                                    <th width="10%" class="text-center">สถานะ</th>
                                    <th width="20%" class="text-center">จัดการ</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (data && data.length > 0) { %>
                                    <% data.forEach((item) => { %>
                                        <tr>
                                            <td class="ps-4">
                                                <div class="d-flex align-items-center">
                                                    <img src="<%= item.profile_image ? '/img/' + item.profile_image : 'https://ui-avatars.com/api/?name=' + item.first_name + '&background=D1E7DD&color=0F5132' %>"
                                                         alt="Profile"
                                                         class="rounded-circle me-3 border" 
                                                         width="40" height="40"
                                                         style="object-fit: cover;"
                                                         onerror="this.onerror=null; this.src='https://ui-avatars.com/api/?name=<%= item.first_name %>&background=D1E7DD&color=0F5132';">
                                                    <div>
                                                        <div class="fw-bold text-dark"><%= item.first_name %> <%= item.last_name %></div>
                                                        <div class="text-muted" style="font-size: 0.8rem;"><%= item.email %></div>
                                                    </div>
                                                </div>
                                            </td>
                                            
                                            <td class="text-center">
                                                <code class="text-success fw-bold"><%= item.teacher_code %></code>
                                            </td>
                                            
                                            <td><span class="text-muted"><%= item.education_level || '-' %></span></td>
                                            
                                            <td><span class="text-muted"><%= item.phone || '-' %></span></td>
                                            
                                            <td class="text-center">
                                                <% if (item.is_active == 1) { %>
                                                    <span class="badge bg-success rounded-pill px-3 py-1 fw-normal shadow-sm">
                                                        ปฏิบัติงาน
                                                    </span>
                                                <% } else { %>
                                                    <span class="badge bg-danger rounded-pill px-3 py-1 fw-normal shadow-sm">
                                                        พ้นสภาพ
                                                    </span>
                                                <% } %>
                                            </td>
                                            
                                            <td class="text-center">
                                                <div class="d-flex justify-content-center gap-2">
                                                    <a href="/admin/man/editTea/<%= item.user_id %>" class="btn btn-outline-primary rounded-pill action-btn shadow-sm">
                                                        <i class="bi bi-pencil-square"></i> แก้ไข
                                                    </a>
                                                    <a href="/admin/man/delTea/<%= item.user_id %>" 
                                                       class="btn btn-outline-danger rounded-pill action-btn shadow-sm"
                                                       onclick="return confirm('ยืนยันการลบข้อมูลอาจารย์ รหัส <%= item.teacher_code %> ออกจากระบบ?');">
                                                        <i class="bi bi-trash3"></i> ลบ
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="6" class="text-center py-5 text-muted">
                                            <i class="bi bi-person-x fs-1 d-block mb-3"></i>
                                            ยังไม่มีข้อมูลอาจารย์ในระบบ
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div> 
                
            </main>
        </div>
    </div>
</body>
</html>