<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Student Information</title>
    <link rel="stylesheet" href="/css/decAdAdd.css">
    <link href="/css/bootstrap.min.css" rel="stylesheet">
    <script src="/js/bootstrap.bundle.min.js"></script>
</head>

<body>
    <%- include("partials/mtbar") %>
        <div class="container mt-5">
    <div class="form-card">
        <h2 class="mb-4 text-center">เพิ่มข้อมูลนักเรียน</h2>
        <form action="/admin/man/saveStu" method="get" class="text-center">
            <div class="row justify-content-center">
                <div class="col-md-8 mb-3">
                    <label for="first" class="form-label">ชื่อ</label>
                    <input type="text" class="form-control mx-auto" style="max-width: 400px;" name="first" id="first" required>
                </div>
                <div class="col-md-6 mb-3">
                    <label for="last" class="form-label">นามสกุล</label>
                    <input type="text" class="form-control mx-auto" style="max-width: 400px;" name="last" id="last" required>
                </div>
            </div>

            <div class="row justify-content-center">
                <div class="col-md-6 mb-3">
                    <label for="gender" class="form-label">เพศ</label>
                    <select class="form-select" name="gender" id="gender">
                        <option value="male" selected>ชาย</option>
                        <option value="female">หญิง</option>
                    </select>
                </div>
                <div class="col-md-6 mb-3">
                    <label for="DOB" class="form-label">วัน - เดือน - ปี เกิด</label>
                    <input type="date"  class="form-control mx-auto" style="max-width: 400px;" name="DOB" id="DOB" required>
                </div>
            </div>

            <div class="mb-3">
                <label for="email" class="form-label">อีเมล</label>
                <input type="email" class="form-control mx-auto" style="max-width: 400px;" name="email" id="email" placeholder="example@mail.com" required>
            </div>

            <div class="row justify-content-center">
                <div class="col-md-6 mb-3">
                    <label for="ID" class="form-label">รหัสประจำตัว</label>
                    <input type="text"  class="form-control mx-auto" style="max-width: 400px;" name="ID" id="ID" required>
                </div>
                <div class="col-md-6 mb-3">
                    <label for="tel" class="form-label">เบอร์โทรศัพท์</label>
                    <input type="tel"  class="form-control mx-auto" style="max-width: 400px;" name="tel" id="tel">
                </div>
            </div>

            <div class="row justify-content-center">
                <div class="col-md-8 mb-3">
                    <label for="password" class="form-label">รหัสผ่าน</label>
                    <input type="password"  class="form-control mx-auto" style="max-width: 400px;" name="password" id="password" required>
                </div>
                <div class="col-md-4 mb-3">
                    <label for="room" class="form-label">รหัสห้อง</label>
                    <input type="number"  class="form-control mx-auto" style="max-width: 400px;" name="room" id="room" required>
                </div>
            </div>

            <div class="row justify-content-center">
                <div class="col-md-8 mb-4">
                    <input type="submit" class="btn btn-primary px-5" value="ยืนยันการเพิ่มข้อมูล">
                </div>
            </div>
        </form>
    </div>
</div>
</body>

</html>