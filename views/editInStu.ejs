<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Student Information</title>
    <link rel="stylesheet" href="/css/decAdEd.css">
        <link href="/css/bootstrap.min.css" rel="stylesheet">
    <script src="/js/bootstrap.bundle.min.js"></script>
    <style>
    </style>
</head>

<body>
    <%- include("partials/mtbar") %>
        <div class="d-flex justify-content-center align-items-center min-vh-100 bg-light">
    <div class="main-card shadow-sm bg-white">
        <div class="row g-0">
            <div class="col-md-4 d-flex flex-column align-items-center justify-content-center border-end bg-light p-4 rounded-start">
                <div class="profile-img-container shadow">
                    <img src="/img/<%= data.profile_image %>" alt="Profile" class="img-fluid">
                </div>
                <h4 class="mt-3 fw-bold"><%= data.first_name %> <%= data.last_name %></h4>
                <p class="text-muted small">Student ID: <%= data.student_code %></p>
            </div>

            <div class="col-md-8 p-5">
                <h2 class="mb-4 fw-bold text-primary">แก้ไขข้อมูลส่วนตัว</h2>
                <form action="/admin/man/changeStu" method="get">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="first" class="form-label">ชื่อ</label>
                            <input type="text" class="form-control" name="first" id="first" value="<%= data.first_name %>" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="last" class="form-label">นามสกุล</label>
                            <input type="text" class="form-control" name="last" id="last" value="<%= data.last_name %>" required>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="gender" class="form-label text-muted">เพศ (แก้ไขไม่ได้)</label>
                            <input type="text" class="form-control bg-light" name="gender" id="gender" value="<%= data.gender %>" readonly>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="DOB" class="form-label text-muted">วัน - เดือน - ปี เกิด (แก้ไขไม่ได้)</label>
                            <input type="text" class="form-control bg-light" name="DOB" id="DOB" value="<%= data.birth_date %>" readonly>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="tel" class="form-label">เบอร์โทรศัพท์</label>
                            <input type="tel" class="form-control" name="tel" id="tel" value="<%= data.phone %>">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="ID" class="form-label text-muted">รหัสประจำตัว (แก้ไขไม่ได้)</label>
                            <input type="text" class="form-control bg-light" name="ID" id="ID" value="<%= data.student_code %>" readonly>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="email" class="form-label text-muted">อีเมล (แก้ไขไม่ได้)</label>
                        <input type="email" class="form-control bg-light" name="email" id="email" value="<%= data.email %>" readonly>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="room" class="form-label">รหัสห้อง</label>
                            <input type="number" class="form-control" name="room" id="room" value="<%= data.homeroom_id %>" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="status" class="form-label">สถานะ</label>
                            <select id="status" name="status" class="form-select border-primary-subtle">
                                <option value="active" <%= data.student_status === 'active' ? 'selected' : '' %>>ยังคงศึกษาอยู่</option>
                                <option value="graduate" <%= data.student_status === 'graduate' ? 'selected' : '' %>>จบการศึกษาแล้ว</option>
                                <option value="rest" <%= data.student_status === 'rest' ? 'selected' : '' %>>ลาพักการศึกษา</option>
                                <option value="drop" <%= data.student_status === 'drop' ? 'selected' : '' %>>ไม่ได้ศึกษาที่นี่แล้ว</option>
                            </select>
                        </div>
                    </div>

                    <div class="mt-4">
                        <button type="submit" class="btn btn-primary w-100 py-3 shadow-sm fw-bold">ยืนยันการเปลี่ยนแปลงข้อมูล</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
</body>

</html>